# cPanel Passenger configuration
PassengerEnabled On
PassengerAppRoot /home/yourusername/perfume_decants
PassengerPython /home/yourusername/perfume_decants/venv/bin/python

# Security headers
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-XSS-Protection "1; mode=block"

# Static/Media files served by Apache
Alias /static/ /home/yourusername/perfume_decants/staticfiles/
Alias /media/ /home/yourusername/perfume_decants/media/

<Directory /home/yourusername/perfume_decants/staticfiles>
    Require all granted
</Directory>

<Directory /home/yourusername/perfume_decants/media>
    Require all granted
</Directory>
